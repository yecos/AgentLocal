# ─── Database ──────────────────────────────────────────────
DATABASE_URL=file:./db/custom.db

# ─── Ollama ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ─── Bridge API (Python backend) ──────────────────────────
BRIDGE_PORT=8000
BRIDGE_HOST=127.0.0.1

# ─── Security ─────────────────────────────────────────────
# Set BRIDGE_TOKEN to enable authentication between Next.js and bridge
# Leave empty for local-only mode (no auth required)
# Example: BRIDGE_TOKEN=my-secret-token-here
BRIDGE_TOKEN=

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Next.js ──────────────────────────────────────────────
# Optional: override default port (default: 3000)
# PORT=3000
