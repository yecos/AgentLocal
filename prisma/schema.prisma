// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AgentLocal Data Models — Complete Schema
// Aligned with API routes (B4 fix + Lote 3 schema-route alignment)
// ============================================================

// --- Conversations & Messages ---

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("New Conversation")
  model     String?
  mode      String    @default("agent") // "agent" or "chat"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  ConversationMessage[]
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // "user", "assistant", "system"
  content        String
  thinking       String?      // Deep thinking content
  toolCalls      String?      // JSON string of tool calls
  tokenCount     Int          @default(0)
  responseTime   Int?         // ms
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// --- Memory ---

model MemoryEntry {
  id        String    @id @default(cuid())
  type      String    // "short_term", "long_term", "working", "episodic", "preference"
  category  String?
  content   String
  context   String?
  confidence Float     @default(1.0)
  source    String?    // "user", "agent", "tool", "learning"
  tags      String?    // JSON array string
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([type])
  @@index([category])
}

// --- Notes ---

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  pinned    Boolean  @default(false)
  tags      String?  // JSON array string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pinned])
}

// --- Projects (aligned with /api/projects route) ---

model Project {
  id          String   @id @default(cuid())
  name        String
  path        String
  language    String?
  framework   String?
  description String?
  status      String   @default("active") // "active", "archived", "deleted"
  gitRepo     String?  // Git repository URL
  lastOpened  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([path])
  @@index([status])
}

// --- Skills (aligned with /api/skills route) ---

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  category    String   @default("general")
  enabled     Boolean  @default(true)
  isLocal     Boolean  @default(true)   // true = 100% local, false = requires cloud API
  isTool      Boolean  @default(false)  // true = callable as a tool by the agent
  useCount    Int      @default(0)      // number of times this skill has been used
  cliCommand  String?                  // CLI command to invoke the skill
  scriptPath  String?                  // path to skill script
  config      String?                  // JSON string with skill-specific configuration
  lastUsedAt  DateTime?               // last time the skill was used
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([enabled])
}

// --- Planning & Tasks (aligned with /api/plans route) ---

model ExecutionPlan {
  id          String   @id @default(cuid())
  goal        String
  description String?                 // Detailed description of the plan
  taskType    String   @default("general") // Kept for backward compat
  planType    String   @default("script")  // "script", "workflow", "pipeline"
  status      String   @default("active")  // "active", "completed", "failed", "paused"
  plan        String?  // JSON string with full plan structure
  result      String?
  progress    Float    @default(0)    // 0.0 - 1.0 completion percentage
  currentTaskId String?               // ID of the currently executing task
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
}

model Task {
  id           String         @id @default(cuid())
  planId       String
  title        String
  description  String?
  status       String         @default("pending") // "pending", "in_progress", "completed", "failed", "skipped"
  priority     String         @default("medium")  // "low", "medium", "high", "critical"
  order        Int            @default(0)
  dependencies String?        // JSON array of task IDs this task depends on
  parentId     String?        // Parent task ID for subtasks
  result       String?
  error        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  plan         ExecutionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([status])
  @@index([priority])
}

// --- Tool Call Logs ---

model ToolCallLog {
  id          String   @id @default(cuid())
  tool        String
  arguments   String?  // JSON string
  result      String?
  success     Boolean  @default(true)
  durationMs  Int?
  conversationId String?
  createdAt   DateTime @default(now())

  @@index([tool])
  @@index([success])
  @@index([createdAt])
}

// --- Agent Configuration ---

model AgentConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general") // "model", "memory", "tools", "ui", "security"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([category])
}
