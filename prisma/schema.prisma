// ==============================================================
// AgentLocal v16 - Prisma Schema
// Esquema de base de datos para el agente autonomo
// ==============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- USUARIO ---

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("user")  // user, admin
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversations Conversation[]
  tasks         Task[]
}

// --- CONVERSACIONES ---

model Conversation {
  id        String   @id @default(cuid())
  title     String   @default("Nueva conversacion")
  userId    String?
  model     String?  // modelo LLM usado
  status    String   @default("active")  // active, archived, deleted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id])
  messages  ConversationMessage[]
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant, system, tool
  content        String
  thinkingLog    String?  // JSON del proceso de pensamiento
  toolCalls      String?  // JSON de las llamadas a herramientas
  modelName      String?  // modelo que genero esta respuesta
  tokens         Int      @default(0)
  duration       Float    @default(0)  // tiempo de respuesta en segundos
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// --- PLANES Y TAREAS ---

model ExecutionPlan {
  id          String   @id @default(cuid())
  goal        String
  description String?
  planType    String   @default("script")  // web_app, script, automation, analysis, project_setup
  status      String   @default("planning")  // planning, in_progress, completed, failed, cancelled
  progress    Float    @default(0)  // 0.0 - 1.0
  currentTaskId String?
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User?  @relation(fields: [userId], references: [id])
  tasks Task[]
}

model Task {
  id           String   @id @default(cuid())
  planId       String
  title        String
  description  String?
  priority     String   @default("medium")  // critical, high, medium, low
  status       String   @default("pending")  // pending, in_progress, completed, failed, cancelled, blocked
  dependencies String?  // JSON: ["taskId1", "taskId2"]
  parentId     String?  // tarea padre (subtareas)
  result       String?
  error        String?
  toolCalls    String?  // JSON de las llamadas a herramientas realizadas
  attempts     Int      @default(0)
  maxAttempts  Int      @default(3)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())

  plan   ExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([status])
}

// --- MEMORIA Y APRENDIZAJE ---

model MemoryEntry {
  id          String   @id @default(cuid())
  type        String   // conversation, correction, knowledge, pattern
  category    String?  // clasificacion (coding, web, system, etc.)
  content     String
  context     String?  // contexto en el que se aprendio
  embedding   String?  // vector embedding como JSON
  confidence  Float    @default(1.0)
  accessCount Int      @default(0)
  source      String?  // web, user, system, tool
  tags        String?  // JSON array de tags
  createdAt   DateTime @default(now())
  accessedAt  DateTime @default(now())
  expiresAt   DateTime?

  @@index([type])
  @@index([category])
}

// --- PROYECTOS ---

model Project {
  id          String   @id @default(cuid())
  name        String
  path        String   // ruta en el filesystem
  description String?
  framework   String?  // nextjs, react, python, etc.
  language    String?  // typescript, python, etc.
  status      String   @default("active")  // active, archived, deleted
  gitRepo     String?  // URL del repositorio git
  lastAnalyzedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([path])
}

// --- LOGS DE HERRAMIENTAS ---

model ToolCallLog {
  id           String   @id @default(cuid())
  toolName     String
  parameters   String?  // JSON de parametros
  result       String?  // resultado truncado
  success      Boolean  @default(true)
  duration     Float    @default(0)  // tiempo en segundos
  errorMessage String?
  conversationId String?
  taskId       String?
  createdAt    DateTime @default(now())

  @@index([toolName])
  @@index([success])
  @@index([createdAt])
}

// --- SKILLS ---

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  category    String?  // web, document, ai, dev, content, analysis
  isTool      Boolean  @default(false)  // es una herramienta usable o solo referencia
  cliCommand  String?  // comando CLI para ejecutar
  scriptPath  String?  // ruta al script
  enabled     Boolean  @default(true)
  lastUsedAt  DateTime?
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([enabled])
}

// --- NOTAS ---

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  userId    String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}

// --- CONFIGURACION ---

model AgentConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  type  String @default("string")  // string, number, boolean, json
}
